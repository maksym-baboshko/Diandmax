{
  "extends": "./configs/typescript/base.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./.cache/typescript/tsconfig.tsbuildinfo"
  },
  "include": [
    "next-env.d.ts",
    "e2e/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "configs/**/*.ts",
    "configs/**/*.tsx",
    "*.config.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "artifacts"]
}
